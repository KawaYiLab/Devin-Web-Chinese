{
  "manifest_version": 3,
  "name": "Devin 网页端汉化",
  "version": "1.0.7",
  "description": "基于静态文本映射的 Devin 网页端汉化插件，将 app.devin.ai 界面文案翻译为中文。",
  "content_scripts": [
    {
      "matches": [
        "https://app.devin.ai/*",
        "https://*.devin.ai/*"
      ],
      "js": [
        "dictionary.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {},
  "permissions": []
}
